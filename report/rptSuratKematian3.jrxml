	<queryString>
		<![CDATA[select date_format(pasien_mati.tanggal,'%d-%m-%Y') as tanggal,pasien_mati.jam,pasien_mati.no_rkm_medis,pasien.nm_pasien, 
				pasien.jk,pasien.tmp_lahir,pasien.tgl_lahir,pasien.gol_darah,pasien.stts_nikah, pasien.umur,pasien.alamat,
				pasien.agama,pasien_mati.temp_meninggal,pasien_mati.icd1,pasien_mati.icd2,
				pasien_mati.icd3,pasien_mati.icd4,pasien_mati.kd_dokter,dokter.nm_dokter, pasien.no_ktp, pasien.agama, TRIM(SUBSTRING_INDEX(pasien_mati.keterangan , '#', 1)) as keterangan, 
				TRIM(SUBSTRING_INDEX(pasien_mati.keterangan , '#', -1)) as no_surat
				from pasien_mati inner join pasien on pasien_mati.no_rkm_medis=pasien.no_rkm_medis 
				inner join dokter on pasien_mati.kd_dokter=dokter.kd_dokter WHERE pasien.no_rkm_medis = $P{no_rm}]]>
	</queryString>
