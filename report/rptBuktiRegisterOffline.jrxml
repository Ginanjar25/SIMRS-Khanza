	<parameter name="alamatrs" class="java.lang.String"/>
	<parameter name="kotars" class="java.lang.String"/>
	<parameter name="propinsirs" class="java.lang.String"/>
	<parameter name="kontakrs" class="java.lang.String"/>
	<parameter name="kodeBooking" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT CONCAT(REPLACE(br.tanggal_periksa,'-',''),br.no_rkm_medis) AS nobooking, dr.nm_dokter, DATE_FORMAT(br.tanggal_periksa, '%d %M %Y') AS tglPeriksa, ps.nm_pasien, pj.png_jawab,
	br.kd_dokter, br.kd_poli, jd.hari_kerja, CONCAT(jd.jam_mulai,'-',jd.jam_selesai) AS jampraktek, REPLACE(br.no_reg,'0','') AS angka,
	CONCAT(br.tanggal_periksa ,' ',DATE_ADD(jd.jam_mulai, INTERVAL ((REPLACE(br.no_reg,'0','')-1)*10) MINUTE)) AS estimasi, CONCAT(mpb.kd_poli_bpjs,'-',br.no_reg) AS noantrean,pl.nm_poli
	FROM booking_registrasi br 
	JOIN poliklinik pl ON pl.kd_poli = br.kd_poli
	JOIN dokter dr ON dr.kd_dokter = br.kd_dokter
	JOIN penjab pj ON pj.kd_pj = br.kd_pj
	JOIN pasien ps ON ps.no_rkm_medis =  br.no_rkm_medis
	JOIN maping_poli_bpjs mpb ON mpb.kd_poli_rs = br.kd_poli
	JOIN jadwal jd ON jd.hari_kerja = 
	    (CASE DAYNAME(br.tanggal_periksa)
	        WHEN 'Sunday' THEN 'AKHAD'
	        WHEN 'Monday' THEN 'SENIN'
	        WHEN 'Tuesday' THEN 'SELASA'
	        WHEN 'Wednesday' THEN 'RABU'
	        WHEN 'Thursday' THEN 'KAMIS'
	        WHEN 'Friday' THEN 'JUMAT'
	        WHEN 'Saturday' THEN 'SABTU'
	    END) AND jd.kd_dokter = br.kd_dokter AND jd.kd_poli = br.kd_poli
	WHERE CONCAT(REPLACE(br.tanggal_periksa,'-',''),br.no_rkm_medis) = $P{kodeBooking}]]>
	</queryString>
	<field name="nobooking" class="java.lang.String"/>
	<field name="nm_dokter" class="java.lang.String"/>
	<field name="tglPeriksa" class="java.lang.String"/>
	<field name="nm_pasien" class="java.lang.String"/>
