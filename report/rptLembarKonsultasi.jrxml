	<parameter name="tgl_konsultasi" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT lembar_konsultasi.no_rawat, reg_periksa.no_rkm_medis, pasien.nm_pasien, pasien.jk, pasien.tgl_lahir, CONCAT(reg_periksa.umurdaftar, ' ', reg_periksa.sttsumur) as umur,
lembar_konsultasi.ruang, lembar_konsultasi.kelas, lembar_konsultasi.tgl_konsultasi,
lembar_konsultasi.kd_dokter_konsul, dokter1.nm_dokter as dokter_konsul, lembar_konsultasi.kd_dokter_dpjp, 
dokter2.nm_dokter as dokter_dpjp, lembar_konsultasi.konsul_dpjp, lembar_konsultasi.jawaban_konsul
FROM lembar_konsultasi
INNER JOIN reg_periksa ON reg_periksa.no_rawat = lembar_konsultasi.no_rawat
INNER JOIN pasien ON pasien.no_rkm_medis = reg_periksa.no_rkm_medis
INNER JOIN dokter as dokter1 ON dokter1.kd_dokter = lembar_konsultasi.kd_dokter_konsul
inner JOIN dokter as dokter2 ON dokter2.kd_dokter = lembar_konsultasi.kd_dokter_dpjp
where lembar_konsultasi.no_rawat = $P{norawat} and lembar_konsultasi.tgl_konsultasi = $P{tgl_konsultasi}]]>
	</queryString>
