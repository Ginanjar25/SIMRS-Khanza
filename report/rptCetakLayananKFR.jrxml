	<queryString language="SQL">
		<![CDATA[select reg_periksa.no_rawat,pasien.no_rkm_medis,pasien.nm_pasien,reg_periksa.umurdaftar,reg_periksa.sttsumur,
pasien.jk,layanan_kfr.anamnesa, layanan_kfr.pemeriksaan_fisik_fungsi, layanan_kfr.diagnosa_medis, layanan_kfr.diagnosa_fungsi,layanan_kfr.pemeriksaan_penunjang,
layanan_kfr.tata_laksana_kfr, layanan_kfr.goal_treatment, layanan_kfr.edukasi, layanan_kfr.anjuran, layanan_kfr.evaluasi,layanan_kfr.suspek_penyakit,
layanan_kfr.ket_suspek_penyakit,dokter.nm_dokter,date_format(pasien.tgl_lahir,'%d-%m-%Y') as lahir,
date_format(layanan_kfr.tanggal,'%d-%m-%Y %T') as periksa, pasien.no_tlp, layanan_kfr.tanggal, layanan_kfr.kd_dokter, pasien.no_peserta
from layanan_kfr inner join reg_periksa on layanan_kfr.no_rawat=reg_periksa.no_rawat 
inner join pasien on reg_periksa.no_rkm_medis=pasien.no_rkm_medis
inner join dokter on layanan_kfr.kd_dokter=dokter.kd_dokter
where layanan_kfr.no_rawat = $P{no_rawat}]]>
	</queryString>
