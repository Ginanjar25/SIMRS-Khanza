	<queryString>
		<![CDATA[select no, temp1, temp2,SUBSTRING_INDEX(temp3,"#",1) AS temp3_1, SUBSTRING_INDEX(temp3,"#",-1) AS temp3, 
temp4, temp5, temp6, temp7, temp8, temp9, temp10, temp11, temp12, temp13, temp14, temp15, temp16,
COALESCE((SELECT saran FROM saran_kesan_lab WHERE no_rawat = $P{noperiksa} ORDER BY tgl_periksa DESC, jam DESC LIMIT 1),'-') AS saran,
COALESCE((SELECT kesan FROM saran_kesan_lab WHERE no_rawat = $P{noperiksa} ORDER BY tgl_periksa DESC, jam DESC LIMIT 1),'-') AS kesan
from temporary_lab order by no ASC]]>
	</queryString>
