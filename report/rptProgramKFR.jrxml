	<queryString language="SQL">
		<![CDATA[SELECT pasien.no_rkm_medis, pasien.nm_pasien,pasien.umur,pasien.jk, pasien.tgl_lahir, program_kfr.tanggal, program_kfr.diagnosa,
program_kfr.perm_terapi,program_kfr.program, petugas.nip, petugas.nama, dokter.kd_dokter, dokter.nm_dokter, pasien.no_peserta
FROM pasien 
INNER JOIN program_kfr ON pasien.no_rkm_medis = program_kfr.no_rkm_medis
INNER JOIN petugas ON program_kfr.nik = petugas.nip
INNER JOIN dokter ON program_kfr.kd_dokter = dokter.kd_dokter
where pasien.no_rkm_medis =  $P{no_rm} order by program_kfr.tanggal]]>
	</queryString>
